# ReplayTrove worker environment template
# Copy values from here into your on-site environment file.
#
# Virtualenv (launcher preflight expects worker\.venv\Scripts\pythonw.exe):
#   cd C:\ReplayTrove\worker
#   py -3 -m venv .venv
#   .\.venv\Scripts\pip install -r requirements.txt
#
# Replay trigger story (HTTP vs legacy): docs/operator-replay-trigger-runbook.md
#
# Central logs root: logs/YYYY-MM-DD/worker.jsonl (+ timeline.jsonl, index.json). Retention: REPLAYTROVE_LOG_RETENTION_DAYS (default 14), REPLAYTROVE_LOG_COMPRESS_OLD=1 optional.
# LOG_FOLDER=C:\ReplayTrove\logs
# Job DB (not under logs/): default C:\ReplayTrove\data\replaytrove_jobs.sqlite
# REPLAYTROVE_DATA_DIR=C:\ReplayTrove\data
# WORKER_JOB_DB=C:\ReplayTrove\data\replaytrove_jobs.sqlite
# Machine heartbeat (system.jsonl): REPLAYTROVE_SYSTEM_HEARTBEAT=1 (default), interval REPLAYTROVE_SYSTEM_HEARTBEAT_INTERVAL_SEC=20

# Preview generation (smaller-file profile)
PREVIEW_WIDTH=426
PREVIEW_CRF=36
PREVIEW_PRESET=fast

# Optional large-clip preview controls
# full | poster | short | defer_after_original
LARGE_PREVIEW_MODE=full
LARGE_PREVIEW_SHORT_SECONDS=15

# Large-clip threshold (bytes) used by LARGE_PREVIEW_MODE
LONG_CLIP_BYTES_THRESHOLD=1073741824

# Preview upload destination (S3 key prefix)
S3_PREVIEW_PREFIX=previews

# Supabase table for booking rows (upsert after Pickle Planner match)
SUPABASE_BOOKINGS_TABLE=bookings

# =============================================================================
# Instant replay — HTTP worker trigger (CANONICAL for appliance operation)
# =============================================================================
# Worker listens for POST /replay when REPLAY_TRIGGER_HTTP_PORT is set (also in unified config:
# worker.httpReplayTriggerHost / worker.httpReplayTriggerPort).
# Operator shortcuts should prefer scripts/save_replay_and_trigger.ps1 (full pipeline) or
# scripts/worker_notify_instant_replay.ps1 -Http (worker-only notify).
# REPLAY_TRIGGER_HTTP_HOST=127.0.0.1
# REPLAY_TRIGGER_HTTP_PORT=18765

# =============================================================================
# LEGACY / EMERGENCY — trigger file & background ingest (NON-CANONICAL)
# =============================================================================
# WARNING: Trigger-file and background-ingest modes bypass the canonical script path.
# Use only for recovery, testing, or transitional installs. Prefer HTTP + save_replay_and_trigger.ps1.
#
# ENABLE_INSTANT_REPLAY_BACKGROUND_INGEST=0
#
# If background ingest is enabled, worker uses trigger-file mode when INSTANT_REPLAY_TRIGGER_FILE
# is set; otherwise poll mode.
# Match REPLAYTROVE_INSTANT_REPLAY_TRIGGER_FILE or -TriggerFile in scripts/worker_notify_instant_replay.ps1
# INSTANT_REPLAY_TRIGGER_FILE=C:\ReplayTrove\state\instant_replay.trigger
# INSTANT_REPLAY_TRIGGER_SETTLE_SECONDS=1.0
#
# Non-canonical background auto-sync LONG_CLIPS_FOLDER -> scoreboard/incoming:
# ENABLE_REPLAY_SCOREBOARD_AUTO_SYNC=0
# REPLAY_SCOREBOARD_AUTO_SYNC_INTERVAL_SECONDS=0
