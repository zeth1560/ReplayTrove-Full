# Copy this file to ".env" in the same folder as settings.py, then edit values.
# Install: pip install python-dotenv (see requirements.txt)
# Already-set Windows/User environment variables take precedence over .env.

# --- Required for capture (use exact name from: python list_uvc_devices.py) ---
# Names with commas (e.g. "UVCHDCAP, Video Capture") are quoted automatically in ffmpeg args.
UVC_VIDEO_DEVICE=

# Audio (DirectShow device name)
# UVC_AUDIO_DEVICE=

# UVC_CAPTURE_BACKEND=dshow

# DirectShow: capture rate must match the device or ffmpeg fails with "Could not set video options"
# (many webcams: 30 fps; HDMI capture dongles often: 60). Final encode rate is LONG_RECORD_OUTPUT_FRAMERATE.
# UVC_DSHOW_VIDEO_SIZE=1920x1080
# UVC_DSHOW_FRAMERATE=60
# UVC_DSHOW_RTBUFSIZE=100M

# Long record (dshow defaults: 60 in, 30 out)
# LONG_RECORD_INPUT_FRAMERATE=60
# LONG_RECORD_OUTPUT_FRAMERATE=30
# Encode size (optional). Default 0x0 = no scale/fps filter (smoothest; uses -r + vsync for output fps only).
# Set both e.g. 1280x720 to downscale and reduce CPU.
# LONG_RECORD_ENCODE_WIDTH=0
# LONG_RECORD_ENCODE_HEIGHT=0
# LONG_RECORD_KEYINT_SECONDS=2
# LONG_RECORD_RTBUFSIZE=512M
# Defaults: superfast, CRF 23, no x264 tune. For speed (worse quality): ultrafast / higher CRF / tune=zerolatency.
# LONG_RECORD_VIDEO_PRESET=superfast
# LONG_RECORD_VIDEO_CRF=23
# LONG_RECORD_LIBX264_TUNE=
# A/V sync (HDMI capture vs USB mic often drift on device timestamps):
# - On Windows, LONG_RECORD_USE_WALLCLOCK_TIMESTAMPS defaults to 1 (set 0 if you see timestamp jitter).
# - If drift remains, try LONG_RECORD_DSHOW_SPLIT_AUDIO=1 (separate dshow graphs for video vs mic).
# - Frame drops (buffer overflow in logs) also cause end-of-clip skew; raise UVC_DSHOW_RTBUFSIZE / LONG_RECORD_RTBUFSIZE.
# Reduce A/V drift when clocks diverge (0 disables aresample async on the audio filter).
# Output AAC sample rate (match capture device to avoid extra resample; override if mic is 48 kHz).
# LONG_RECORD_AUDIO_SAMPLE_RATE=44100
# LONG_RECORD_AUDIO_ARESAMPLE_ASYNC_MAX=1000
# Fixed alignment: positive ms shifts audio earlier (use when sound is behind the picture); negative delays audio.
# Example: ~400 ms late → LONG_RECORD_AUDIO_SYNC_OFFSET_MS=400
# LONG_RECORD_AUDIO_SYNC_OFFSET_MS=400
# LONG_RECORD_DSHOW_SPLIT_AUDIO=0
# LONG_RECORD_USE_WALLCLOCK_TIMESTAMPS=1

# FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe

# Paths
# LONG_CLIPS_FOLDER=C:\ReplayTrove\long_clips
# ENCODER_STATE_PATH=C:\ReplayTrove\scoreboard\encoder_state.json
# ENCODER_LOG_DIR=C:\ReplayTrove\logs

# UI: on Windows the default is hidden (no taskbar / no focus); use normal for a local debug window.
# ENCODER_UI_MODE=hidden
# ENCODER_UI_MODE=normal

# Supervise operator + auto-restart on bad encoder_state.json (run: python encoder_watchdog.py)
# WATCHDOG_POLL_INTERVAL=2
# WATCHDOG_STARTUP_GRACE_SECONDS=45
# WATCHDOG_STALE_STATE_SECONDS=90
# WATCHDOG_MAX_RESTARTS=15
# WATCHDOG_RESTART_WINDOW_SECONDS=600
# WATCHDOG_OPERATOR_SCRIPT=
# WATCHDOG_RESTART_ON_ZERO_EXIT=0

# Restart: launcher should relaunch on ENCODER_APP_RESTART_EXIT_CODE (default 75)
# ENCODER_SELF_RESTART_ENABLED=0
