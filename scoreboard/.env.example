# Optional overrides (defaults match prior hardcoded paths)
# STATE_FILE=state.json
# SCOREBOARD_BACKGROUND_IMAGE=Score BG.png
# REPLAY_SLATE_IMAGE=ir slate.png
SLIDESHOW_DIR=C:\Users\admin\Dropbox\slideshow
REPLAY_VIDEO_PATH=C:\ReplayTrove\INSTANTREPLAY.mkv
# Full-screen graphic when replay cannot run (default assets/replay_unavailable.png).
# REPLAY_UNAVAILABLE_IMAGE=assets/replay_unavailable.png
# Reject replay if file mtime is older than this many seconds (stale clip / OBS not writing). 0 = disable check.
# REPLAY_FILE_MAX_AGE_SECONDS=120
# When instant replay file is missing/empty/stale, OBS WebSocket BroadcastCustomEvent (payload: source, event, reason).
# REPLAY_OBS_BROADCAST_ON_UNAVAILABLE=1
# REPLAY_LAUNCHER_RESTART_OBS_ON_UNAVAILABLE=1
# REPLAY_LAUNCHER_RESTART_OBS_SCRIPT=C:\ReplayTrove\launcher\restart_obs.ps1
MPV_PATH=C:\Program Files\mpv\mpv.exe
MPV_EXIT_HOTKEY=Ctrl+Alt+q
MPV_EMBEDDED=0
# Instant-replay mpv subprocess (see replay_controller._build_mpv_argv)
# OBS coexistence (defaults reduce GPU/present contention with OBS capture + NVENC):
# MPV_OBS_FRIENDLY=1
# MPV_REPLAY_QUALITY=fast          # fast | balanced (spline36) | hq (gpu-hq profile)
# MPV_BORDERLESS_FULLSCREEN=1    # borderless fill via --geometry=100%x100%+0+0 + --hidpi-window-scale=no (not fixed Tk pixels)
# MPV_OBS_LOWER_PROCESS_PRIORITY=1
# MPV_OBS_FORCE_SOFTWARE_DECODE=1  # force --hwdec=no even if MPV_HWDEC_ENABLED=1 (NVENC + D3D11VA often clash)
# MPV_HWDEC_ENABLED=0
# MPV_HWDEC_MODE=auto
# MPV_FULLSCREEN_ENABLED=1
# MPV_KEEP_OPEN_ENABLED=1
# MPV_LOOP_ENABLED=1
# MPV_VIDEO_SYNC_MODE=display-resample
# MPV_FRAMEDROP_MODE=vo
# MPV_INTERPOLATION_ENABLED=0
# MPV_FORCE_WINDOW_ENABLED=1
# MPV_ADDITIONAL_ARGS=--profile=low-latency --untimed --vd-lavc-threads=1
# MPV_PROCESS_PRIORITY=normal
# or MPV_PROCESS_PRIORITY=low (Windows below-normal process priority; also used when OBS_FRIENDLY+normal)
SYNTHETIC_FOCUS_CLICK=1
# Recording overlay: drive start/dismiss/black-screen/replay-buffer-loading via JSON commands
# (see C:\ReplayTrove\commands\scoreboard\pending and scripts\send_command.ps1).
RECORDING_MAX_MINUTES=20
# Optional: before starting the recording timer, probe OBS via WebSocket 5 (OBS 28+).
# Catches hung OBS (no reply) or main Record output still active. Requires: pip install obsws-python
# RECORDING_OBS_HEALTH_CHECK=1
# OBS_WEBSOCKET_HOST=localhost
# OBS_WEBSOCKET_PORT=4455
# OBS_WEBSOCKET_PASSWORD=
# OBS_WEBSOCKET_TIMEOUT_SEC=2.0
# Quick check (same probe as scoreboard readiness):  python test_obs_websocket.py
# If you only use Source Record (never main Record), set 0 so an active main output does not block:
# RECORDING_OBS_BLOCK_IF_MAIN_RECORDING=0
# If 0 (recommended for live ops), timer still starts when OBS WebSocket probe fails.
# If 1, failed gate shows unavailable graphic and blocks timer start.
# RECORDING_OBS_HEALTH_FAIL_CLOSED=0
#
# Simultaneous Stream Deck keys Q + R + P (within ~75 ms): restart OBS on Windows, then optionally
# start the replay buffer via WebSocket (requires obsws-python; same host/port/password as above).
# OBS_RESTART_CHORD_ENABLED=1
# OBS_EXECUTABLE=
# Match launcher flags; clearing %APPDATA%\\obs-studio\\.sentinel is what fixes OBS 32+ safe-mode prompt.
# OBS_RESTART_LAUNCH_ARGS=--disable-shutdown-check --disable-missing-files-check --startreplaybuffer
# OBS_RESTART_START_REPLAY_BUFFER=1
# OBS_RESTART_POST_LAUNCH_DELAY_MS=4500
#
# Bottom-left strip: VIDEO RECORDER READY / UNAVAILABLE (OBS WebSocket; requires obsws-python).
# OBS_STATUS_INDICATOR_ENABLED=1
# OBS_STATUS_POLL_INTERVAL_MS=4000
# Keep 0 if you want READY when OBS is reachable even if main output is currently recording.
# OBS_STATUS_REQUIRE_MAIN_OUTPUT_IDLE=0
# How long the max-length message stays if no one dismisses it (minutes, min 1).
RECORDING_ENDED_HOLD_MINUTES=2
#
# After replay, use command ``replay_buffer_loading`` to show replay-buffer lockout graphics
# (Loading01.png … Loading11.png, native size, lower-right) for 3s each (~33s total).
# Place PNGs under assets/replay_buffer_loading/ (repo default) or set REPLAY_BUFFER_LOADING_DIR.
# REPLAY_BUFFER_LOADING_DIR=assets/replay_buffer_loading
# REPLAY_BUFFER_LOADING_FRAME_MS=3000
# REPLAY_BUFFER_LOADING_MARGIN_PX=24
#
# Encoder appliance status (lower-left PNGs on main canvas; reads encoder_state.json).
# Match ENCODER_STATE_PATH with the encoder app's setting (default: encoder_state.json in repo root).
# ENCODER_STATUS_ENABLED=1
# ENCODER_STATE_PATH=encoder_state.json
# ENCODER_STATUS_READY_IMAGE=assets/recorderstatus/ready.png
# ENCODER_STATUS_UNAVAILABLE_IMAGE=assets/recorderstatus/unavailable.png
# ENCODER_STATUS_POLL_MS=2000
# ENCODER_STATUS_STALE_SECONDS=45
# ENCODER_STATUS_MARGIN_PX=24
#
# Recording in-progress timer overlay: start/stop from encoder_state.json (long recording).
# Same file as ENCODER_STATE_PATH. Freshness uses ENCODER_STATUS_STALE_SECONDS (updated_at).
# Set to 0 to drive the overlay only from UI/commands (not encoder_state.json).
# RECORDING_ENCODER_SYNC_ENABLED=1
# RECORDING_ENCODER_POLL_MS=1000
#
# Launcher integration: JSON for C:\ReplayTrove\launcher (screensaver on/off, process running).
# Default path: C:\ReplayTrove\launcher\scoreboard_status.json
# SCOREBOARD_LAUNCHER_STATUS_ENABLED=1
# SCOREBOARD_LAUNCHER_STATUS_PATH=C:\ReplayTrove\launcher\scoreboard_status.json
#
# Companion page switching (scoreboard-driven; prevents premature page switch when replay fails).
# Set enabled + three Companion HTTP /api/location/.../press URLs:
# - replay_on accepted by scoreboard => Replay Active page
# - replay_off accepted by scoreboard => Replay Locked page
# - Instant replay NOT ready (OBS/mpv/replay file) => Replay Locked page (idle + periodic checks)
# - Instant replay ready => Replay Idle page; after lockout animation ends => Idle if still ready, else Locked
# COMPANION_PAGE_SWITCH_ENABLED=1
# COMPANION_REPLAY_ACTIVE_PAGE_URL=http://127.0.0.1:8000/YOUR_ACTIVE_PAGE_WEBHOOK
# COMPANION_REPLAY_LOCKED_PAGE_URL=http://127.0.0.1:8000/YOUR_LOCKED_PAGE_WEBHOOK
# COMPANION_REPLAY_IDLE_PAGE_URL=http://127.0.0.1:8000/YOUR_IDLE_PAGE_WEBHOOK
# Default 1: idle vs locked follows OBS WebSocket readiness. Set 0 to show Companion idle when
# mpv + replay file (+ worker /health if HTTP trigger is on) are OK even if OBS WS is down
# (replay may still fail until OBS is reachable).
# COMPANION_READINESS_REQUIRE_OBS_WEBSOCKET=1
# Readiness uses the same OBS WebSocket probe as the optional OBS status strip; if that strip is
# disabled, readiness is re-checked every 15s. Enable OBS status indicator for faster updates.
# When worker.httpReplayTriggerEnabled is true, scoreboard also GETs http://host:port/health
# (REPLAY_TRIGGER_HTTP_* env overrides). HTTP trigger off => worker health check skipped.

# --- Pilot / reliability (optional) ---
# REPLAY_ENABLED=1
# Set to 0 for scoreboard-only if video or mpv is not ready (startup will not require them).
# SLIDESHOW_ENABLED=1
# Set to 0 to disable idle slideshow entirely (no slideshow directory required at startup).
# SCOREBOARD_DEBUG=0
# Set to 1 for DEBUG logging, scheduler after() schedule/cancel traces, extra focus logs.
# Central JSONL logs: logs/YYYY-MM-DD/scoreboard.jsonl (+ timeline, index). Override root:
# REPLAYTROVE_LOGS_ROOT=C:\ReplayTrove\logs
# Optional extra rotating *text* log in addition to JSONL (5 MB x 5). Empty default = JSONL only.
# SCOREBOARD_LOG_FILE=logs/scoreboard.log
# Set to 0/none/off for no legacy text file.
# HEARTBEAT_INTERVAL_MINUTES=0
# e.g. 10 for a lightweight INFO log every 10 minutes (0 = disabled).
# REPLAY_TRANSITION_TIMEOUT_MS=90000
# If fade-in/out hangs, force return to normal scoreboard after this many ms.
# REPLAY_SLATE_STUCK_TIMEOUT_MS=90000
# After slate is shown, if mpv never starts within (launch delay + this), force recovery.
# Delay after slate is visible before launching mpv (OBS/disk flush). Default 1000 ms; raise if clips are incomplete.
# REPLAY_VIDEO_START_DELAY_MS=1000
# Command bus poll (send_command / Stream Deck). Default 25 ms (was 100 ms). Min 10; max 500.
# SCOREBOARD_COMMAND_POLL_MS=25
